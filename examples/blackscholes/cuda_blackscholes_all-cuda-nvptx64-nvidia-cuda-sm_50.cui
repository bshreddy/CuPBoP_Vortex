# 5 "./cudaBlackScholes_common.h" 2


inline float cnd_approx(float x) {


    const float inv_sqrt2 = 0.70710678118654752440f;
    return 0.5f * erfcf(-x * inv_sqrt2);
}


inline void black_scholes_cpu_one(
    float S, float K, float T, float R, float V,
    float& call, float& put)
{
    float sqrtT = std::sqrt(T);
    float d1 = (std::log(S / K) + (R + 0.5f * V * V) * T) / (V * sqrtT);
    float d2 = d1 - V * sqrtT;
    float CNDD1 = cnd_approx(d1);
    float CNDD2 = cnd_approx(d2);
    float expRT = std::exp(-R * T);
    call = S * CNDD1 - K * expRT * CNDD2;
    put = K * expRT * (1.0f - CNDD2) - S * (1.0f - CNDD1);
}


inline void black_scholes_cpu(
    float* call, float* put,
    const float* S, const float* K, const float* T,
    float R, float V, int n)
{
    for (int i = 0; i < n; ++i) {
        black_scholes_cpu_one(S[i], K[i], T[i], R, V, call[i], put[i]);
    }
}
# 15 "./cuda_blackscholes_all.cu" 2


__attribute__((device)) inline float cnd_approx_dev(float x) {
    const float inv_sqrt2 = 0.70710678118654752440f;

    return 0.5f * erfcf(-x * inv_sqrt2);
}

__attribute__((global)) void black_scholes_kernel(
    float* d_call, float* d_put,
    const float* d_S, const float* d_K, const float* d_T,
    float R, float V, int n)
{
    int idx = blockDim.x * blockIdx.x + threadIdx.x;
    if (idx >= n) return;

    float S = d_S[idx];
    float K = d_K[idx];
    float T = d_T[idx];

    float sqrtT = sqrtf(T);
    float d1 = (logf(S / K) + (R + 0.5f * V * V) * T) / (V * sqrtT);
    float d2 = d1 - V * sqrtT;
    float CNDD1 = cnd_approx_dev(d1);
    float CNDD2 = cnd_approx_dev(d2);
    float expRT = __expf(-R * T);

    d_call[idx] = S * CNDD1 - K * expRT * CNDD2;
    d_put[idx] = K * expRT * (1.0f - CNDD2) - S * (1.0f - CNDD1);
}


extern "C" void BlackScholesGPU(
    float* h_call, float* h_put,
    const float* h_S, const float* h_K, const float* h_T,
    float R, float V, int n, int blockSize)
{
    float *d_call=nullptr, *d_put=nullptr, *d_S=nullptr, *d_K=nullptr, *d_T=nullptr;
    size_t bytes = sizeof(float) * n;

    do { cudaError_t _err = (cudaMalloc(&d_call, bytes)); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaMalloc(&d_call, bytes)", "./cuda_blackscholes_all.cu", 55, cudaGetErrorString(_err)); std::exit(1); } } while (0);
    do { cudaError_t _err = (cudaMalloc(&d_put, bytes)); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaMalloc(&d_put, bytes)", "./cuda_blackscholes_all.cu", 56, cudaGetErrorString(_err)); std::exit(1); } } while (0);
    do { cudaError_t _err = (cudaMalloc(&d_S, bytes)); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaMalloc(&d_S, bytes)", "./cuda_blackscholes_all.cu", 57, cudaGetErrorString(_err)); std::exit(1); } } while (0);
    do { cudaError_t _err = (cudaMalloc(&d_K, bytes)); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaMalloc(&d_K, bytes)", "./cuda_blackscholes_all.cu", 58, cudaGetErrorString(_err)); std::exit(1); } } while (0);
    do { cudaError_t _err = (cudaMalloc(&d_T, bytes)); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaMalloc(&d_T, bytes)", "./cuda_blackscholes_all.cu", 59, cudaGetErrorString(_err)); std::exit(1); } } while (0);

    do { cudaError_t _err = (cudaMemcpy(d_S, h_S, bytes, cudaMemcpyHostToDevice)); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaMemcpy(d_S, h_S, bytes, cudaMemcpyHostToDevice)", "./cuda_blackscholes_all.cu", 61, cudaGetErrorString(_err)); std::exit(1); } } while (0);
    do { cudaError_t _err = (cudaMemcpy(d_K, h_K, bytes, cudaMemcpyHostToDevice)); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaMemcpy(d_K, h_K, bytes, cudaMemcpyHostToDevice)", "./cuda_blackscholes_all.cu", 62, cudaGetErrorString(_err)); std::exit(1); } } while (0);
    do { cudaError_t _err = (cudaMemcpy(d_T, h_T, bytes, cudaMemcpyHostToDevice)); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaMemcpy(d_T, h_T, bytes, cudaMemcpyHostToDevice)", "./cuda_blackscholes_all.cu", 63, cudaGetErrorString(_err)); std::exit(1); } } while (0);

    int grid = (n + blockSize - 1) / blockSize;
    black_scholes_kernel<<<grid, blockSize>>>(d_call, d_put, d_S, d_K, d_T, R, V, n);
    do { cudaError_t _err = (cudaGetLastError()); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaGetLastError()", "./cuda_blackscholes_all.cu", 67, cudaGetErrorString(_err)); std::exit(1); } } while (0);
    do { cudaError_t _err = (cudaDeviceSynchronize()); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaDeviceSynchronize()", "./cuda_blackscholes_all.cu", 68, cudaGetErrorString(_err)); std::exit(1); } } while (0);

    do { cudaError_t _err = (cudaMemcpy(h_call, d_call, bytes, cudaMemcpyDeviceToHost)); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaMemcpy(h_call, d_call, bytes, cudaMemcpyDeviceToHost)", "./cuda_blackscholes_all.cu", 70, cudaGetErrorString(_err)); std::exit(1); } } while (0);
    do { cudaError_t _err = (cudaMemcpy(h_put, d_put, bytes, cudaMemcpyDeviceToHost)); if (_err != cudaSuccess) { fprintf(stderr, "[CUDA] %s failed at %s:%d: %s\n", "cudaMemcpy(h_put, d_put, bytes, cudaMemcpyDeviceToHost)", "./cuda_blackscholes_all.cu", 71, cudaGetErrorString(_err)); std::exit(1); } } while (0);

    cudaFree(d_call);
    cudaFree(d_put);
    cudaFree(d_S);
    cudaFree(d_K);
    cudaFree(d_T);
}
# 88 "./cuda_blackscholes_all.cu"
extern "C" void BlackScholesGPU(
    float* h_call, float* h_put,
    const float* h_S, const float* h_K, const float* h_T,
    float R, float V, int n, int blockSize);



extern "C" void BlackScholes(
    float *CallResult, float *PutResult,
    float *StockPrice, float *OptionStrike, float *OptionYears,
    float Riskfree, float Volatility,
    unsigned options, unsigned groupSize, unsigned )
{

    int blockSize = (groupSize == 0) ? 256 : static_cast<int>(groupSize);
    BlackScholesGPU(CallResult, PutResult,
                    StockPrice, OptionStrike, OptionYears,
                    Riskfree, Volatility, static_cast<int>(options), blockSize);
}

extern "C" void closeBlackScholes(
    float *CallResult, float *PutResult,
    float *StockPrice, float *OptionStrike, float *OptionYears,
    float Riskfree, float Volatility,
    unsigned options, unsigned short )
{

    BlackScholesGPU(CallResult, PutResult,
                    StockPrice, OptionStrike, OptionYears,
                    Riskfree, Volatility, static_cast<int>(options), 256);
}
