# 100 "/nethome/cahn45/vortex_after_2.0/kernel/include/vx_intrinsics.h"
inline void vx_tmc(int thread_mask) {
    __asm__ volatile (".insn r %0, 0, 0, x0, %1, x0" :: "i"(0x0B), "r"(thread_mask));
}


inline void vx_tmc_zero() {
    __asm__ volatile (".insn r %0, 0, 0, x0, x0, x0" :: "i"(0x0B));
}


inline void vx_tmc_one() {
    __asm__ volatile (
        "li a0, 1\n\t"
        ".insn r %0, 0, 0, x0, a0, x0" :: "i"(0x0B) : "a0"
    );
}


inline void vx_pred(int condition, int thread_mask) {
    __asm__ volatile (".insn r %0, 5, 0, x0, %1, %2" :: "i"(0x0B), "r"(condition), "r"(thread_mask));
}


inline void vx_pred_n(int condition, int thread_mask) {
    __asm__ volatile (".insn r %0, 5, 0, x1, %1, %2" :: "i"(0x0B), "r"(condition), "r"(thread_mask));
}


typedef void (*vx_wspawn_pfn)();
inline void vx_wspawn(int num_warps, vx_wspawn_pfn func_ptr) {
    __asm__ volatile (".insn r %0, 1, 0, x0, %1, %2" :: "i"(0x0B), "r"(num_warps), "r"(func_ptr));
}


inline int vx_split(int predicate) {
    int ret;
    __asm__ volatile (".insn r %1, 2, 0, %0, %2, x0" : "=r"(ret) : "i"(0x0B), "r"(predicate));
    return ret;
}


inline int vx_split_n(int predicate) {
    int ret;
    __asm__ volatile (".insn r %1, 2, 0, %0, %2, x1" : "=r"(ret) : "i"(0x0B), "r"(predicate));
    return ret;
}


inline void vx_join(int stack_ptr) {
    __asm__ volatile (".insn r %0, 3, 0, x0, %1, x0" :: "i"(0x0B), "r"(stack_ptr));
}


inline void vx_barrier(int barried_id, int num_warps) {
    __asm__ volatile (".insn r %0, 4, 0, x0, %1, %2" :: "i"(0x0B), "r"(barried_id), "r"(num_warps));
}


inline __attribute__((const)) int vx_thread_id() {
    int ret;
    __asm__ volatile ("csrr %0, %1" : "=r"(ret) : "i"(0xCC0));
    return ret;
}


inline __attribute__((const)) int vx_warp_id() {
    int ret;
    __asm__ volatile ("csrr %0, %1" : "=r"(ret) : "i"(0xCC1));
    return ret;
}


inline __attribute__((const)) int vx_core_id() {
    int ret;
    __asm__ volatile ("csrr %0, %1" : "=r"(ret) : "i"(0xCC2));
    return ret;
}


inline __attribute__((const)) int vx_active_threads() {
    int ret;
    __asm__ volatile ("csrr %0, %1" : "=r"(ret) : "i"(0xCC4));
    return ret;
}


inline __attribute__((const)) int vx_active_warps() {
    int ret;
    __asm__ volatile ("csrr %0, %1" : "=r"(ret) : "i"(0xCC3));
    return ret;
}


inline __attribute__((const)) int vx_num_threads() {
    int ret;
    __asm__ volatile ("csrr %0, %1" : "=r"(ret) : "i"(0xFC0));
    return ret;
}


inline __attribute__((const)) int vx_num_warps() {
    int ret;
    __asm__ volatile ("csrr %0, %1" : "=r"(ret) : "i"(0xFC1));
    return ret;
}


inline __attribute__((const)) int vx_num_cores() {
    int ret;
    __asm__ volatile ("csrr %0, %1" : "=r"(ret) : "i"(0xFC2));
    return ret;
}


inline __attribute__((const)) int vx_hart_id() {
    int ret;
    __asm__ volatile ("csrr %0, %1" : "=r"(ret) : "i"(0xF14));
    return ret;
}

inline void vx_fence() {
    __asm__ volatile ("fence iorw, iorw");
}


inline __attribute__((const)) int vx_vote_all(int predicate) {
    int ret;
    __asm__ volatile (".insn r %1, 0, 1, %0, %2, x0" : "=r"(ret) : "i"(0x0B), "r"(predicate));
    return ret;
}


inline __attribute__((const)) int vx_vote_any(int predicate) {
    int ret;
    __asm__ volatile (".insn r %1, 1, 1, %0, %2, x0" : "=r"(ret) : "i"(0x0B), "r"(predicate));
    return ret;
}


inline __attribute__((const)) int vx_vote_uni(int predicate) {
    int ret;
    __asm__ volatile (".insn r %1, 2, 1, %0, %2, x0" : "=r"(ret) : "i"(0x0B), "r"(predicate));
